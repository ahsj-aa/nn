<?xml version="1.0"?>
<mujoco model="humanoid">
  <compiler inertiafromgeom="true" angle="degree"/>
  <default>
    <joint limited="true" damping="0.5" armature="0.001"/>
    <geom condim="3" friction="0.8 0.1 0.1" solref="0.02 1"/>
    <motor gear="50" ctrllimited="true" ctrlrange="-0.4 0.4"/>
  </default>
  <option timestep="0.001" iterations="50"/>
  <visual>
    <global offwidth="800" offheight="800"/>
  </visual>
  <asset>
    <texture name="body" type="cube" builtin="flat" width="128" height="128" rgb1="0.8 0.6 0.4"/>
    <material name="body" texture="body" texuniform="true"/>
  </asset>
  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1"/>
    <geom type="plane" size="10 10 0.1" rgba="0.9 0.9 0.9 1"/>

    <body name="torso" pos="0 0 1.4">
      <freejoint/>
      <geom name="torso_geom" type="capsule" size="0.15" fromto="0 0 0 0 0 0.45" material="body"/>

      <!-- 右大腿 -->
      <body name="right_thigh" pos="0 -0.15 -0.25">
        <joint name="right_hip_pitch" type="hinge" axis="1 0 0" range="-45 45"/>
        <joint name="right_hip_roll"  type="hinge" axis="0 1 0" range="-30 30"/>
        <geom type="capsule" size="0.12" fromto="0 0 0 0 0 -0.4" material="body"/>

        <!-- 右小腿 -->
        <body name="right_shin" pos="0 0 -0.4">
          <joint name="right_knee" type="hinge" axis="1 0 0" range="-120 0"/>
          <geom type="capsule" size="0.1" fromto="0 0 0 0 0 -0.4" material="body"/>

          <!-- 右脚 -->
          <body name="right_foot" pos="0 0 -0.4">
            <joint name="right_ankle_pitch" type="hinge" axis="1 0 0" range="-30 30"/>
            <joint name="right_ankle_roll"  type="hinge" axis="0 1 0" range="-15 15"/>
            <geom type="box" size="0.15 0.1 0.05" pos="0 0 -0.05" material="body"/>
          </body>
        </body>
      </body>

      <!-- 左大腿 -->
      <body name="left_thigh" pos="0 0.15 -0.25">
        <joint name="left_hip_pitch" type="hinge" axis="1 0 0" range="-45 45"/>
        <joint name="left_hip_roll"  type="hinge" axis="0 1 0" range="-30 30"/>
        <geom type="capsule" size="0.12" fromto="0 0 0 0 0 -0.4" material="body"/>

        <!-- 左小腿 -->
        <body name="left_shin" pos="0 0 -0.4">
          <joint name="left_knee" type="hinge" axis="1 0 0" range="-120 0"/>
          <geom type="capsule" size="0.1" fromto="0 0 0 0 0 -0.4" material="body"/>

          <!-- 左脚 -->
          <body name="left_foot" pos="0 0 -0.4">
            <joint name="left_ankle_pitch" type="hinge" axis="1 0 0" range="-30 30"/>
            <joint name="left_ankle_roll"  type="hinge" axis="0 1 0" range="-15 15"/>
            <geom type="box" size="0.15 0.1 0.05" pos="0 0 -0.05" material="body"/>
          </body>
        </body>
      </body>

      <!-- 右臂 -->
      <body name="right_upperarm" pos="0 -0.2 0.2">
        <joint name="right_shoulder_pitch" type="hinge" axis="1 0 0" range="-90 90"/>
        <joint name="right_shoulder_roll"  type="hinge" axis="0 1 0" range="-45 45"/>
        <geom type="capsule" size="0.08" fromto="0 0 0 0 0 -0.3" material="body"/>
        <body name="right_forearm" pos="0 0 -0.3">
          <joint name="right_elbow" type="hinge" axis="0 1 0" range="0 90"/>
          <geom type="capsule" size="0.07" fromto="0 0 0 0 0 -0.25" material="body"/>
        </body>
      </body>

      <!-- 左臂 -->
      <body name="left_upperarm" pos="0 0.2 0.2">
        <joint name="left_shoulder_pitch" type="hinge" axis="1 0 0" range="-90 90"/>
        <joint name="left_shoulder_roll"  type="hinge" axis="0 1 0" range="-45 45"/>
        <geom type="capsule" size="0.08" fromto="0 0 0 0 0 -0.3" material="body"/>
        <body name="left_forearm" pos="0 0 -0.3">
          <joint name="left_elbow" type="hinge" axis="0 1 0" range="0 90"/>
          <geom type="capsule" size="0.07" fromto="0 0 0 0 0 -0.25" material="body"/>
        </body>
      </body>

    </body>
  </worldbody>

  <actuator>
    <motor joint="right_hip_pitch"/>
    <motor joint="right_hip_roll"/>
    <motor joint="right_knee"/>
    <motor joint="right_ankle_pitch"/>
    <motor joint="right_ankle_roll"/>

    <motor joint="left_hip_pitch"/>
    <motor joint="left_hip_roll"/>
    <motor joint="left_knee"/>
    <motor joint="left_ankle_pitch"/>
    <motor joint="left_ankle_roll"/>

    <motor joint="right_shoulder_pitch"/>
    <motor joint="right_shoulder_roll"/>
    <motor joint="right_elbow"/>

    <motor joint="left_shoulder_pitch"/>
    <motor joint="left_shoulder_roll"/>
    <motor joint="left_elbow"/>
  </actuator>
</mujoco>